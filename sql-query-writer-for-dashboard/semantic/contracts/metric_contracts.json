        "gaotu_crm_offline_statistics.app_mcrm_first_call_task_hf",
        "finance_dw.dim_finance_employee_df"
      ],
      "calculation_grain": [
        "period_name",
        "employee_email_name"
      ],
      "allowed_dimensions": [
        "market_consultant:dimension:period_name",
        "market_consultant:dimension:channel_map",
        "market_consultant:dimension:stats_grade_name",
        "market_consultant:dimension:employee_email_name",
        "market_consultant:dimension:virtual_manager",
        "market_consultant:dimension:virtual_supervisor"
      ],
      "required_scope_fields": [
        "dt",
        "hour",
        "section_assign_employee_first_level_department_name",
        "section_assign_employee_second_level_department_name",
        "virtual_third_department_name",
        "period_mapping_first_level_department_name",
        "period_mapping_second_level_department_name"
      ],
      "notes": "is_f_call 必须由首 call 任务表 first_call_status = 3 经 account_id 员工维桥接生成，禁止从旧过程表 call_answer_lead_count 取值。"
