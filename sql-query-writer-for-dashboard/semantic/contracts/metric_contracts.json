    {
      "id": "market_consultant:metric:first_call_within_24h_rate",
      "name": "24小时外呼率",
      "aliases": [
        "24h外呼率",
        "24小时首呼率",
        "24h首呼及时率",
        "first_call_24h_rate"
      ],
      "status": "confirmed",
      "source_path": "knowledge/metrics/outbound_call_process_metrics.md",
      "source_sha256": "459a7f3e52ed291e96e533f05ad2f669442c0a8affe0c9dfa83738383bd73e5e",
      "description": "24 小时内完成首呼的有效线索数除以有效线索数。",
      "sql_expression": "coalesce(sum({base}.first_call_in_24h) / nullif(sum({base}.valid_lead_count), 0), 0)",
      "output_alias": "first_call_24h_rate",
      "aggregation": "ratio_of_sums",
      "automatic_compile": false,
      "candidate_tables": [
        "bdg_ba.dm_crm_lead_cost_gmv_communication_learn_full_link_df",
        "service_dw.app_h_crm_lead_employee_workload_detail_hf"
      ],
      "calculation_grain": [
        "period_name",
        "channel_map",
        "employee_email_name"
      ],
      "allowed_dimensions": [
        "market_consultant:dimension:period_name",
        "market_consultant:dimension:channel_map",
        "market_consultant:dimension:stats_grade_name",
        "market_consultant:dimension:employee_email_name",
        "market_consultant:dimension:virtual_manager",
        "market_consultant:dimension:virtual_supervisor"
      ],
      "required_scope_fields": [
        "dt",
        "hour",
        "section_assign_employee_first_level_department_name",
        "section_assign_employee_second_level_department_name",
        "virtual_third_department_name",
        "period_mapping_first_level_department_name",
        "period_mapping_second_level_department_name"
      ],
      "notes": "比率必须在最终聚合粒度按分子分母重算，禁止对行级比率求和或平均。"
    },
    {
      "id": "market_consultant:metric:first_call_task_rate",
      "name": "首call任务率",
      "aliases": [
        "首call率",
