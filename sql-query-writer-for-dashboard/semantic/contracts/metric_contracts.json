      "source_sha256": "f7131b48bd29a7d44c24002dbc08a90d1039e17dca778de98b3e6c0e52a447dc",
      "description": "历史市场顾问转化看板明确输出的截面转化线索人数。",
      "sql_expression": "sum({base}.conversion_lead_count)",
      "output_alias": "pay_users",
      "aggregation": "sum",
      "automatic_compile": true,
      "candidate_tables": [
        "bdg_ba.dm_crm_lead_cost_gmv_communication_learn_full_link_df"
