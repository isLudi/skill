      "description": "历史市场转化看板以期次、归一化渠道和年级关联成本目标临时表。",
      "left_table": "bdg_ba.dm_crm_lead_cost_gmv_communication_learn_full_link_df",
      "right_table": "temp_table.dingxi01_cost",
      "key_pairs": [
        {
          "left_field": "period_name",
          "right_field": "qici"
        },
        {
          "left_field": "channel_map",
          "right_field": "channel"
        },
        {
          "left_field": "grade_1",
          "right_field": "grade"
        }
      ],
      "cardinality": "many_to_one_if_right_unique",
