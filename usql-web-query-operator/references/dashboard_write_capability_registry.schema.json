{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/usql/dashboard_write_capability_registry.schema.json",
  "title": "Taitan dashboard write capability registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "platform",
    "default_policy",
    "capabilities",
    "registry_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "artifact_type": {"const": "DashboardWriteCapabilityRegistry"},
    "platform": {"const": "taitan"},
    "default_policy": {"const": "block_unverified"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/capability"}
    },
    "registry_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "source_sha256", "note"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "note": {"type": "string", "minLength": 1}
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "phase",
        "maturity",
        "write_policy",
        "transaction_class",
        "recovery_policy",
        "readback_coverage",
        "risk",
        "adapter",
        "write_endpoints",
        "readback_endpoints",
        "evidence",
        "limitations"
      ],
      "properties": {
        "operation": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "phase": {"enum": ["draft", "publish", "permission", "folder"]},
        "maturity": {"enum": ["verified", "sandbox_verified", "partial", "observed", "unverified"]},
        "write_policy": {"enum": ["allowlisted", "sandbox_only", "separate_confirmation", "blocked"]},
        "transaction_class": {"enum": ["compensating_restore", "creation_saga", "separate_publish", "none"]},
        "recovery_policy": {"enum": ["compensating_restore", "creation_saga_no_auto_delete", "separate_publish", "blocked_no_adapter"]},
        "readback_coverage": {"enum": ["full", "partial", "none"]},
        "risk": {"enum": ["low", "medium", "high", "critical"]},
        "adapter": {"type": ["string", "null"]},
        "write_endpoints": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "readback_endpoints": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
