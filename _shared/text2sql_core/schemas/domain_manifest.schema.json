{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/text2sql/domain_manifest.schema.json",
  "title": "Text2SQL domain manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "domain",
    "authority",
    "progressive_disclosure",
    "boundary",
    "counts",
    "entities",
    "reverse_lookup",
    "source_inventory",
    "semantic_contracts"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "domain": {
      "type": "object",
      "required": ["id", "name", "skill", "isolated_from"],
      "properties": {
        "id": {"enum": ["market_consultant", "qingcheng"]},
        "name": {"type": "string"},
        "skill": {"type": "string"},
        "isolated_from": {"type": "array", "minItems": 1, "uniqueItems": true}
      }
    },
    "authority": {"type": "object"},
    "progressive_disclosure": {"type": "object"},
    "boundary": {"type": "object"},
    "counts": {"type": "object"},
    "entities": {"type": "object"},
    "reverse_lookup": {"type": "object"},
    "source_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path", "sha256", "bytes", "category"],
        "properties": {
          "source_path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0},
          "category": {"type": "string"}
        }
      }
    },
    "semantic_contracts": {"type": "object"}
  }
}
