{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/text2sql/domain_manifest.schema.json",
  "title": "Text2SQL domain manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "domain",
    "authority",
    "progressive_disclosure",
    "boundary",
    "counts",
    "current_model_registry",
    "dashboard_registry",
    "entities",
    "reverse_lookup",
    "source_inventory",
    "semantic_contracts"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "domain": {
      "type": "object",
      "required": ["id", "name", "skill", "isolated_from"],
      "properties": {
        "id": {"enum": ["market_consultant", "qingcheng"]},
        "name": {"type": "string"},
        "skill": {"type": "string"},
        "isolated_from": {"type": "array", "minItems": 1, "uniqueItems": true}
      }
    },
    "authority": {"type": "object"},
    "progressive_disclosure": {"type": "object"},
    "boundary": {"type": "object"},
    "counts": {"type": "object"},
    "current_model_registry": {
      "type": "object",
      "required": [
        "source_path",
        "source_sha256",
        "policy",
        "canonical_filename_policy",
        "model_count",
        "semantic_slot_count"
      ],
      "properties": {
        "source_path": {"const": "semantic/current_model_bindings.json"},
        "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "policy": {"const": "one_current_model_per_id_and_semantic_slot"},
        "canonical_filename_policy": {"type": "string", "minLength": 1},
        "model_count": {"type": "integer", "minimum": 0},
        "semantic_slot_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "dashboard_registry": {
      "type": "object",
      "required": ["source", "policy", "count", "registered", "cross_domain_conflicts"],
      "properties": {
        "source": {"const": "knowledge/dashboard_web_profiles"},
        "policy": {
          "const": "unregistered_or_cross_domain_dashboard_blocks_design_and_mutation"
        },
        "count": {"type": "integer", "minimum": 0},
        "registered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dashboard_id", "status", "evidence"],
            "properties": {
              "dashboard_id": {"type": "string", "minLength": 1},
              "status": {"const": "registered"},
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["source_path", "source_sha256"],
                  "properties": {
                    "source_path": {"type": "string", "minLength": 1},
                    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "cross_domain_conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dashboard_id", "domains"],
            "properties": {
              "dashboard_id": {"type": "string", "minLength": 1},
              "domains": {
                "type": "array",
                "minItems": 2,
                "uniqueItems": true,
                "items": {"enum": ["market_consultant", "qingcheng"]}
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "entities": {"type": "object"},
    "reverse_lookup": {"type": "object"},
    "source_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path", "sha256", "bytes", "category"],
        "properties": {
          "source_path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0},
          "category": {"type": "string"}
        }
      }
    },
    "semantic_contracts": {"type": "object"}
  }
}
