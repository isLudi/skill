{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/text2sql/dashboard_build_plan.schema.json",
  "title": "Resolved read-only P4C dashboard build plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "mode", "domain", "build_id",
    "dashboard_build_spec_sha256", "status", "target_folder",
    "folder_snapshot_sha256", "dashboard_name", "dashboard_name_available",
    "datasets", "calculated_columns", "components", "global_filters", "theme",
    "validation_checks", "required_capabilities", "production_adapter", "pending_reasons",
    "blocked_reasons", "transaction_class", "recovery_policy", "write_boundary",
    "target_state_sha256", "dashboard_build_plan_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "dashboard_build_plan"},
    "mode": {"const": "read_only_plan"},
    "domain": {"enum": ["market_consultant", "qingcheng"]},
    "build_id": {"type": "string", "minLength": 1},
    "dashboard_build_spec_sha256": {"$ref": "#/$defs/sha256"},
    "status": {"enum": ["ready", "pending_dataset_creation", "blocked"]},
    "target_folder": {"type": "object"},
    "folder_snapshot_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "dashboard_name": {"type": "string", "minLength": 1},
    "dashboard_name_available": {"type": ["boolean", "null"]},
    "datasets": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "calculated_columns": {"type": "array", "items": {"type": "object"}},
    "components": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "global_filters": {"type": "array", "items": {"type": "object"}},
    "theme": {"type": "object"},
    "validation_checks": {"type": "array", "minItems": 1},
    "required_capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "production_adapter": {"const": "taitan_dashboard_build_v1"},
    "pending_reasons": {"type": "array", "items": {"type": "string"}},
    "blocked_reasons": {"type": "array", "items": {"type": "string"}},
    "transaction_class": {"const": "creation_saga"},
    "recovery_policy": {"const": "creation_saga_no_auto_delete"},
    "write_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorizes_data_center_apply", "authorizes_dashboard_apply", "authorizes_publish", "requires_exact_plan_sha256", "requires_production_confirmation"],
      "properties": {
        "authorizes_data_center_apply": {"const": false},
        "authorizes_dashboard_apply": {"const": false},
        "authorizes_publish": {"const": false},
        "requires_exact_plan_sha256": {"const": true},
        "requires_production_confirmation": {"const": true}
      }
    },
    "target_state_sha256": {"$ref": "#/$defs/sha256"},
    "dashboard_build_plan_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
