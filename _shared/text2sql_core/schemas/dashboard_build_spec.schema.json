{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/text2sql/dashboard_build_spec.schema.json",
  "title": "Declarative P4C dashboard build specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "mode", "domain", "build_id",
    "target_folder", "dashboard_name", "datasets", "calculated_columns",
    "components", "containers", "text_components", "global_filters", "theme", "validation_checks",
    "publish_requested", "write_boundary", "dashboard_build_spec_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "artifact_type": {"const": "dashboard_build_spec"},
    "mode": {"const": "read_only_declaration"},
    "domain": {"enum": ["market_consultant", "qingcheng"]},
    "build_id": {"$ref": "#/$defs/logical_id"},
    "target_folder": {"$ref": "#/$defs/folder"},
    "dashboard_name": {"type": "string", "minLength": 1},
    "datasets": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/dataset"}},
    "calculated_columns": {"type": "array", "items": {"$ref": "#/$defs/calculated_column"}},
    "components": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/component"}},
    "containers": {"type": "array", "items": {"$ref": "#/$defs/container"}},
    "text_components": {"type": "array", "items": {"$ref": "#/$defs/text_component"}},
    "global_filters": {"type": "array", "items": {"$ref": "#/$defs/global_filter"}},
    "theme": {"type": "object"},
    "validation_checks": {"type": "array", "minItems": 1},
    "publish_requested": {"const": false},
    "write_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["may_plan", "may_create_draft", "may_publish", "requires_exact_plan_sha256", "requires_production_confirmation"],
      "properties": {
        "may_plan": {"const": true},
        "may_create_draft": {"const": false},
        "may_publish": {"const": false},
        "requires_exact_plan_sha256": {"const": true},
        "requires_production_confirmation": {"const": true}
      }
    },
    "dashboard_build_spec_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "logical_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "folder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["folder_id", "folder_path", "folder_name"],
      "properties": {
        "folder_id": {"type": "string", "minLength": 1},
        "folder_path": {"type": "string", "minLength": 1},
        "folder_name": {"type": "string", "minLength": 1}
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_ref", "mode", "domain", "query_plan_path", "query_plan_sha256",
        "dataset_spec_path", "dataset_spec_sha256", "application_model_id",
        "subject_id", "model_type", "data_center_creation_plan_path",
        "data_center_creation_plan_sha256", "data_center_creation_receipt_path",
        "data_center_creation_receipt_sha256", "config"
      ],
      "properties": {
        "dataset_ref": {"$ref": "#/$defs/logical_id"},
        "mode": {"enum": ["existing", "create"]},
        "domain": {"enum": ["market_consultant", "qingcheng"]},
        "query_plan_path": {"type": ["string", "null"]},
        "query_plan_sha256": {"$ref": "#/$defs/sha256"},
        "dataset_spec_path": {"type": ["string", "null"]},
        "dataset_spec_sha256": {"$ref": "#/$defs/sha256"},
        "application_model_id": {"type": ["string", "null"]},
        "subject_id": {"type": ["string", "null"]},
        "model_type": {},
        "data_center_creation_plan_path": {"type": ["string", "null"]},
        "data_center_creation_plan_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "data_center_creation_receipt_path": {"type": ["string", "null"]},
        "data_center_creation_receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "identity_resolution_required": {"type": "boolean"},
        "creation_plan_required": {"type": "boolean"},
        "config": {"type": "object"}
      }
    },
    "calculated_column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_id", "dataset_ref", "name", "data_type", "formula_template", "dependencies", "config"],
      "properties": {
        "logical_id": {"$ref": "#/$defs/logical_id"},
        "dataset_ref": {"$ref": "#/$defs/logical_id"},
        "name": {"type": "string", "minLength": 1},
        "data_type": {"type": "string", "minLength": 1},
        "formula_template": {"type": "string", "minLength": 1},
        "dependencies": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "config": {"type": "object"}
      }
    },
    "filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_ref", "operator", "values", "required", "config"],
      "properties": {
        "field_ref": {"type": "string", "minLength": 1},
        "operator": {"type": "string", "minLength": 1},
        "values": {"type": "array"},
        "required": {"type": "boolean"},
        "config": {"type": "object"}
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_ref", "x", "y", "w", "h"],
      "properties": {
        "container_ref": {"type": "string", "minLength": 1},
        "x": {"type": "number"}, "y": {"type": "number"},
        "w": {"type": "number", "exclusiveMinimum": 0},
        "h": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "type", "unit_type", "dataset_ref", "title", "dimensions", "measures", "local_filters", "display", "style", "container_ref", "slot_ref", "layout"],
      "properties": {
        "component_id": {"$ref": "#/$defs/logical_id"},
        "type": {"enum": ["metric_group", "pivot", "bar", "pie"]},
        "unit_type": {"enum": ["card", "u_pivot", "u_bar", "u_pie"]},
        "dataset_ref": {"$ref": "#/$defs/logical_id"},
        "title": {"type": "string"},
        "dimensions": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "measures": {"type": "array", "items": {"$ref": "#/$defs/measure"}},
        "local_filters": {"type": "array", "items": {"$ref": "#/$defs/filter"}},
        "display": {"type": "object"},
        "style": {"type": "object"},
        "container_ref": {"type": ["string", "null"]},
        "slot_ref": {"type": ["string", "null"]},
        "layout": {"$ref": "#/$defs/layout"}
      }
    },
    "measure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_ref", "display_name"],
      "properties": {
        "field_ref": {"type": "string", "minLength": 1},
        "display_name": {"type": ["string", "null"]}
      }
    },
    "container": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_id", "type", "component_name", "title", "description", "slots", "style", "layout"],
      "properties": {
        "container_id": {"$ref": "#/$defs/logical_id"},
        "type": {"const": "tabs"},
        "component_name": {"const": "SingleTabs"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "slots": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["slot_id", "label"],
            "properties": {
              "slot_id": {"$ref": "#/$defs/logical_id"},
              "label": {"type": "string", "minLength": 1}
            }
          }
        },
        "style": {"type": "object"},
        "layout": {"$ref": "#/$defs/layout"}
      }
    },
    "text_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text_id", "type", "component_name", "title", "initial_text", "content_html", "style", "layout"],
      "properties": {
        "text_id": {"$ref": "#/$defs/logical_id"},
        "type": {"const": "text"},
        "component_name": {"const": "Text"},
        "title": {"type": "string"},
        "initial_text": {"type": "string", "minLength": 1},
        "content_html": {"type": "string", "minLength": 1, "maxLength": 20000},
        "style": {"type": "object"},
        "layout": {"$ref": "#/$defs/layout"}
      }
    },
    "global_filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filter_id", "dataset_ref", "title", "field_ref", "operator", "default_values", "target_component_refs", "config"],
      "properties": {
        "filter_id": {"$ref": "#/$defs/logical_id"},
        "dataset_ref": {"$ref": "#/$defs/logical_id"},
        "title": {"type": "string"},
        "field_ref": {"type": "string", "minLength": 1},
        "operator": {"type": "string", "minLength": 1},
        "default_values": {"type": "array"},
        "target_component_refs": {"type": "array", "items": {"$ref": "#/$defs/logical_id"}, "minItems": 1},
        "config": {"type": "object"}
      }
    }
  }
}
