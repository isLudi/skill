      "source_sha256": "94e1b87c2a17820b431ad107dc6fa2a9b3d54b3e8ae29cd2d9666e7ebf00d307",
      "filters": [
        {
          "field": "path_name",
          "operator": "LIKE",
          "value": "高途-H业务线-青橙项目部%"
        },
        {
          "field": "employee_first_level_department_name",
          "operator": "=",
          "value": "H业务线"
        },
        {
          "field": "employee_second_level_department_name",
          "operator": "=",
          "value": "青橙项目部"
        },
        {
          "field": "coalesce(order_attr.original_paid_time, paid_time, trade_time)",
          "operator": "BETWEEN_EMPLOYMENT_WINDOW",
          "value": {
            "begin_field": "begin_time",
            "end_field": "end_time",
            "allow_null_end": true
          }
        }
      ],
      "applies_to_tables": [
        "finance_dw.app_finance_performance_extend_details_hf",
        "dw.dim_employee_chain"
      ],
      "partition_requirements": [
        "dt",
        "hour"
      ],
      "notes": [
        "现行完成度口径优先使用 original_paid_time 判断任职窗口；team_hist 期次只作为已有文档明确的兜底。"
